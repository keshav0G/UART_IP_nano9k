    .RESET(n32_5) 
);
  DFFRE tx_data_1_s0 (
    .Q(tx_data[1]),
    .D(rx_data_Z[1]),
    .CLK(clk_d),
    .CE(n21_4),
    .RESET(n32_5) 
);
  DFFRE tx_data_0_s0 (
    .Q(tx_data[0]),
    .D(rx_data_Z[0]),
    .CLK(clk_d),
    .CE(n21_4),
    .RESET(n32_5) 
);
  DFFR wr_en_s0 (
    .Q(wr_en),
    .D(n21_4),
    .CLK(clk_d),
    .RESET(n32_5) 
);
  DFFRE tx_data_7_s0 (
    .Q(tx_data[7]),
    .D(rx_data_Z[7]),
    .CLK(clk_d),
    .CE(n21_4),
    .RESET(n32_5) 
);
  INV n32_s2 (
    .O(n32_5),
    .I(rst_btn_d) 
);
  baud_rate_gen baud_inst (
    .clk_d(clk_d),
    .rst_btn_d(rst_btn_d),
    .n38_5(n38_5),
    .rx_acc(rx_acc[3:0]),
    .tx_acc_0(tx_acc[0]),
    .tx_acc_1(tx_acc[1]),
    .tx_acc_3(tx_acc[3]),
    .tx_acc_5(tx_acc[5]),
    .tx_acc_6(tx_acc[6]),
    .tx_acc_7(tx_acc[7])
);
  transmitter tx_inst (
    .clk_d(clk_d),
    .n32_5(n32_5),
    .wr_en(wr_en),
    .n38_5(n38_5),
    .tx_data(tx_data[7:0]),
    .tx_acc_0(tx_acc[0]),
    .tx_acc_1(tx_acc[1]),
    .tx_acc_3(tx_acc[3]),
    .tx_acc_5(tx_acc[5]),
    .tx_acc_6(tx_acc[6]),
    .tx_acc_7(tx_acc[7]),
    .uart_tx_d(uart_tx_d),
    .state(state[1:0])
);
  receiver rx_inst (
    .clk_d(clk_d),
    .n32_5(n32_5),
    .uart_rx_d(uart_rx_d),
    .rst_btn_d(rst_btn_d),
    .rx_acc(rx_acc[3:0]),
