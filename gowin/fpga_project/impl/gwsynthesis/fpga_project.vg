module top (
  clk,
  rst_btn,
  uart_tx,
  uart_rx
)
;
input clk;
input rst_btn;
output uart_tx;
input uart_rx;
wire clk_d;
wire rst_btn_d;
wire uart_rx_d;
wire n21_4;
wire wr_en;
wire n32_5;
wire n38_5;
wire uart_tx_d;
wire rx_valid_Z;
wire [7:0] tx_data;
wire [3:0] rx_acc;
wire [7:0] tx_acc;
wire [1:0] state;
wire [7:0] rx_data_Z;
wire VCC;
wire GND;
  IBUF clk_ibuf (
    .O(clk_d),
    .I(clk) 
);
  IBUF rst_btn_ibuf (
    .O(rst_btn_d),
    .I(rst_btn) 
);
  IBUF uart_rx_ibuf (
    .O(uart_rx_d),
    .I(uart_rx) 
);
  OBUF uart_tx_obuf (
    .O(uart_tx),
    .I(uart_tx_d) 
);
  LUT3 n21_s0 (
    .F(n21_4),
    .I0(state[0]),
    .I1(state[1]),
    .I2(rx_valid_Z) 
);
defparam n21_s0.INIT=8'h10;
  DFFRE tx_data_6_s0 (
    .Q(tx_data[6]),
    .D(rx_data_Z[6]),
    .CLK(clk_d),
    .CE(n21_4),
    .RESET(n32_5) 
);
  DFFRE tx_data_5_s0 (
    .Q(tx_data[5]),
    .D(rx_data_Z[5]),
    .CLK(clk_d),
    .CE(n21_4),
    .RESET(n32_5) 
);
  DFFRE tx_data_4_s0 (
    .Q(tx_data[4]),
    .D(rx_data_Z[4]),
    .CLK(clk_d),
    .CE(n21_4),
    .RESET(n32_5) 
);
  DFFRE tx_data_3_s0 (
    .Q(tx_data[3]),
    .D(rx_data_Z[3]),
    .CLK(clk_d),
    .CE(n21_4),
    .RESET(n32_5) 
);
  DFFRE tx_data_2_s0 (
    .Q(tx_data[2]),
    .D(rx_data_Z[2]),
